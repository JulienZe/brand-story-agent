# ========================================
# 品牌故事创作智能体 - 环境变量配置
# ========================================

# 应用配置
NODE_ENV=development
PORT=3001

# ========================================
# AI模型配置
# ========================================
# 可选提供商: ollama, siliconflow, deepseek, xfyun, claude, openai, mock
# 推荐: ollama (免费本地部署) 或 siliconflow (免费额度)
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:7b
AI_FALLBACK_ENABLED=true
AI_FALLBACK_ORDER=ollama,siliconflow,deepseek,mock

# AI速率限制
AI_RATE_LIMIT=60
AI_MAX_RETRIES=3
AI_RETRY_BACKOFF=1000

# 成本追踪
AI_COST_TRACKING=true

# ========================================
# Ollama 本地模型（免费）
# ========================================
# 本地Ollama服务地址
OLLAMA_BASE_URL=http://localhost:11434
# Ollama模型列表:
#   qwen2.5:7b       - 通义千问2.5 7B (推荐，中文强，已安装) ⭐
#   qwen2.5:latest   - 通义千问2.5 latest
#   qwen2.5-coder:14b-base-q2_K - 通义千问Coder 14B (代码强)
#   deepcoder:latest - DeepCoder (代码生成)
#   marco-o1:latest  - Marco-o1 (推理优化)

# ========================================
# 硅基流动（免费额度）
# ========================================
# 获取地址: https://www.siliconflow.cn/
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ========================================
# DeepSeek（便宜）
# ========================================
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ========================================
# 讯飞星火（免费额度）
# ========================================
# 获取地址: https://xinghuo.xfyun.cn/
XFYUN_API_KEY=your_xfyun_api_key_here
XFYUN_APP_ID=your_xfyun_app_id_here
XFYUN_API_SECRET=your_xfyun_api_secret_here

# ========================================
# Claude（付费）
# ========================================
# 获取地址: https://www.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_BASE_URL=https://api.anthropic.com

# ========================================
# OpenAI（付费）
# ========================================
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com

# ========================================
# 工作流配置
# ========================================
WORKFLOW_PERSISTENCE=false
WORKFLOW_STORAGE=memory
WORKFLOW_TIMEOUT=300000

# ========================================
# 推荐配置
# ========================================

# 方案1: Ollama本地部署（推荐，完全免费）
# 1. 安装Ollama: https://ollama.com/
# 2. 下载模型: ollama pull qwen3:8b
# 3. 启动服务: ollama serve
# 4. 设置下方变量:
# AI_PROVIDER=ollama
# AI_MODEL=qwen3:8b

# 方案2: 硅基流动（国内可用，有免费额度）
# 1. 注册: https://www.siliconflow.cn/
# 2. 获取API Key
# 3. 设置下方变量:
# AI_PROVIDER=siliconflow
# AI_MODEL=Qwen/Qwen2.5-7B-Instruct

# 方案3: DeepSeek（性价比高）
# 1. 注册: https://platform.deepseek.com/
# 2. 获取API Key
# 3. 设置下方变量:
# AI_PROVIDER=deepseek
# AI_MODEL=deepseek-chat
